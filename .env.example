# ── OpenClaw Project WebOS ──
# Copy to .env and fill in your values.

# Server
PORT=3876

# Database (PostgreSQL required)
STORAGE_TYPE=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openclaw_webos
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change-me

# OpenClaw Integration (optional — needed for model catalog sync)
OPENCLAW_WORKSPACE=/path/to/openclaw/workspace
OPENCLAW_CONFIG_FILE=/path/to/openclaw/openclaw.json
OPENCLAW_BIN=openclaw
